{
  "expo": {
    "name": "FITCORE",
    "slug": "fitcore",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "fitcore",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#080808",
    "splash": {
      "backgroundColor": "#080808"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.fitcore.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#080808"
      },
      "package": "com.fitcore.app"
    },
    "web": {
      "bundler": "metro",
      "output": "single"
    },
    "plugins": [
      "expo-router",
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
